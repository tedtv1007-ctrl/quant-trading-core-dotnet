@page "/"
@using QuantTrading.Core.Models
@using QuantTrading.Core.Services
@using QuantTrading.Web.Services
@using System.Reactive.Linq
@inject TradingStateService State
@inject TradingConfiguration Config
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard - QuantTrading</PageTitle>

<div class="qt-page-title">
    <div class="d-flex align-items-center justify-content-between w-100">
        <div>
            <i class="bi bi-grid-1x2-fill title-icon"></i> Trading Dashboard
        </div>
        <button class="btn btn-sm btn-link text-muted" @onclick="ToggleGlobalStats" style="text-decoration:none">
            <i class="bi @(showGlobalStats ? "bi-chevron-up" : "bi-chevron-down")"></i>
            @(showGlobalStats ? "Hide Stats" : "Show Stats")
        </button>
    </div>
</div>

@* ── Global Summary Stats ── *@
@if (showGlobalStats)
{
    <div class="row g-3 mb-4">
        <div class="col-md col-6">
            <div class="qt-stat-card @(State.IsSimulationRunning ? "accent-green qt-pulse" : "")">
                <i class="bi bi-activity stat-icon"></i>
                <div class="stat-label">Status</div>
                <div class="stat-value @(State.IsSimulationRunning ? "text-profit" : "text-neutral")">@State.SimulationStatus</div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="qt-stat-card accent-blue">
                <i class="bi bi-eye stat-icon"></i>
                <div class="stat-label">Watchlist</div>
                <div class="stat-value">@watchlist.Count</div>
                <div class="stat-sub">stocks monitored</div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="qt-stat-card accent-purple">
                <i class="bi bi-arrow-left-right stat-icon"></i>
                <div class="stat-label">Today's Trades</div>
                <div class="stat-value">@State.DailyTradeCount <span style="font-size:0.8rem;color:var(--qt-text-muted)">/ @Config.RiskConfig.MaxDailyTrades</span></div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="qt-stat-card @(State.DailyRealizedLoss > Config.RiskConfig.MaxDailyLoss * 0.6m ? "accent-red" : "accent-yellow")">
                <i class="bi bi-shield-exclamation stat-icon"></i>
                <div class="stat-label">Daily Loss</div>
                <div class="stat-value @(State.DailyRealizedLoss > Config.RiskConfig.MaxDailyLoss * 0.6m ? "text-loss" : "")">$@State.DailyRealizedLoss.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="qt-stat-card accent-green">
                <i class="bi bi-lightning-charge stat-icon"></i>
                <div class="stat-label">Total Signals</div>
                <div class="stat-value text-profit">@signals.Count</div>
            </div>
        </div>
    </div>
}

@* ── Per-Ticker Consoles ── *@
@if (watchlist.Any())
{
    <div class="qt-section-header">
        <i class="bi bi-collection section-icon"></i>
        <h5>Monitored Consoles</h5>
    </div>

    @foreach (var w in watchlist)
    {
        var tickerSignals = signals.Where(s => s.Ticker == w.Ticker).ToList();
        var tickerRejections = rejections.Where(r => r.Ticker == w.Ticker).ToList();
        var latestTick = ticks.LastOrDefault(t => t.Ticker == w.Ticker);
        var priceChange = latestTick != null && w.RefPrice > 0
            ? ((latestTick.Price - w.RefPrice) / w.RefPrice * 100) : 0;

        <div class="ticker-console-row">
            @* ── Left: Info Panel ── *@
            <div class="ticker-info-panel">
                <div class="qt-ticker-card @(w.IsRunning ? "active" : "") h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong style="font-size:1.1rem; color:var(--qt-text)">@w.Ticker</strong>
                        <span class="qt-badge @GetStatusBadgeClass(w)">@w.Status</span>
                    </div>

                    <div style="height:40px; width:100%; margin-bottom:0.75rem; overflow:hidden">
                        <svg viewBox="0 0 100 40" preserveAspectRatio="none" style="width:100%; height:100%">
                            <polyline fill="none" stroke="@(priceChange >= 0 ? "var(--qt-green)" : "var(--qt-red)")" 
                                      stroke-width="1.5" points="@GetSparklinePoints(w.Ticker)" />
                        </svg>
                    </div>

                    <div class="text-center mb-2">
                        @if (latestTick != null)
                        {
                            <div style="font-size:1.75rem; font-weight:700; font-family:'JetBrains Mono',monospace"
                                 class="@(priceChange >= 0 ? "text-profit" : "text-loss")">
                                @latestTick.Price.ToString("F2")
                            </div>
                            <small class="@(priceChange >= 0 ? "text-profit" : "text-loss")">
                                @(priceChange >= 0 ? "▲" : "▼") @priceChange.ToString("F2")%
                            </small>
                        }
                        else
                        {
                            <div style="font-size:1.4rem; font-family:'JetBrains Mono',monospace; color:var(--qt-text-muted)">@w.RefPrice.ToString("F1")</div>
                            <small class="text-neutral">Ref Price</small>
                        }
                    </div>

                    @{ var (longPct, shortPct) = GetPowerLevel(w.Ticker); }
                    <div style="margin-bottom:0">
                        <div class="d-flex justify-content-between" style="font-size:0.65rem; color:var(--qt-text-dim); margin-bottom:2px">
                            <span>LONG @longPct%</span>
                            <span>SHORT @shortPct%</span>
                        </div>
                        <div style="height:4px; display:flex; background:var(--qt-bg-surface); border-radius:2px; overflow:hidden">
                            <div style="width:@longPct%; background:var(--qt-green)"></div>
                            <div style="width:@shortPct%; background:var(--qt-red)"></div>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Middle: Signals Panel (Only show if has signals) ── *@
            @if (tickerSignals.Any())
            {
                <div class="ticker-log-panel">
                    <div class="ticker-log-header text-profit">
                        <i class="bi bi-lightning-charge-fill"></i> Recent Signals
                    </div>
                    <div style="overflow-y:auto; flex:1">
                        <table class="qt-table">
                            <tbody>
                                @foreach (var s in tickerSignals.AsEnumerable().Reverse().Take(5))
                                {
                                    <tr>
                                        <td class="mono" style="width:80px">@s.Timestamp.ToString("HH:mm")</td>
                                        <td><span class="qt-badge @(s.Strategy == StrategyType.OpenGap ? "qt-badge-green" : "qt-badge-blue")">@s.Strategy</span></td>
                                        <td class="mono">@s.EntryPrice.ToString("F1")</td>
                                        <td class="mono text-muted">SL: @s.StopLossPrice.ToString("F1")</td>
                                        <td class="mono">@s.PositionSize 股</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ── Right: Rejections Panel (Only show if has rejections) ── *@
            @if (tickerRejections.Any())
            {
                <div class="ticker-log-panel" style="flex: 0 0 300px;">
                    <div class="ticker-log-header text-loss">
                        <i class="bi bi-x-octagon-fill"></i> Risk Rejections
                    </div>
                    <div style="overflow-y:auto; flex:1">
                        <table class="qt-table">
                            <tbody>
                                @foreach (var r in tickerRejections.AsEnumerable().Reverse().Take(5))
                                {
                                    <tr>
                                        <td class="mono" style="width:80px">@r.Timestamp.ToString("HH:mm")</td>
                                        <td><span class="qt-badge qt-badge-red">@r.Reason</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ── Placeholder if nothing happening ── *@
            @if (!tickerSignals.Any() && !tickerRejections.Any())
            {
                <div class="d-flex align-items-center justify-content-center flex-grow-1" style="border:1px dashed var(--qt-border); border-radius:var(--qt-radius); color:var(--qt-text-dim); font-size:0.8rem">
                    <i class="bi bi-search me-2"></i> Scanning market for opportunities...
                </div>
            }
        </div>
    }
}

@* ── Recent Ticks ── *@
<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="qt-card">
            <div class="qt-card-header" style="color:var(--qt-blue)">
                <i class="bi bi-graph-up-arrow"></i> Global Live Ticks
            </div>
            <div class="qt-card-body p-0">
                @if (ticks.Any())
                {
                    <div style="max-height:200px; overflow-y:auto">
                        <table class="qt-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Ticker</th>
                                    <th>Price</th>
                                    <th>Volume</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in ticks.AsEnumerable().Reverse().Take(20))
                                {
                                    <tr style="color: @GetTickColor(t)">
                                        <td class="mono">@t.Timestamp.ToString("HH:mm:ss")</td>
                                        <td><strong>@t.Ticker</strong></td>
                                        <td class="mono">
                                            @if (t.Type == TickType.Up) { <span>▲ </span> }
                                            else if (t.Type == TickType.Down) { <span>▼ </span> }
                                            @t.Price.ToString("F2")
                                        </td>
                                        <td class="mono">@t.Volume</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="padding:1.5rem; text-align:center; color:var(--qt-text-dim)">
                        No tick data
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<WatchlistEntry> watchlist = new();
    private List<SignalContext> signals = new();
    private List<RejectedSignal> rejections = new();
    private List<TickData> ticks = new();
    private IDisposable? _subscription;
    private bool showGlobalStats = true;

    protected override void OnInitialized()
    {
        // 建立 Rx.NET Observable，匯流 State.OnStateChanged 事件並節流為 250ms
        _subscription = Observable.FromEvent(
            h => State.OnStateChanged += h,
            h => State.OnStateChanged -= h)
            .Sample(TimeSpan.FromMilliseconds(250))
            .Subscribe(_ => InvokeAsync(RefreshData));

        RefreshData();
    }

    private void ToggleGlobalStats()
    {
        showGlobalStats = !showGlobalStats;
    }

    private void RefreshData()
    {
        watchlist = State.GetWatchlist();
        signals = State.GetSignals();
        rejections = State.GetRejections();
        ticks = State.GetRecentTicks();
        InvokeAsync(StateHasChanged);
    }

    private string GetStatusBadgeClass(WatchlistEntry w)
    {
        if (w.IsRunning) return "qt-badge-yellow";
        if (w.Status.Contains("Completed")) return "qt-badge-green";
        if (w.Status.Contains("Error")) return "qt-badge-red";
        return "qt-badge-blue";
    }

    private string GetTickColor(TickData t)
    {
        return t.Type switch
        {
            TickType.Up => "var(--qt-profit)",
            TickType.Down => "var(--qt-loss)",
            _ => "var(--qt-text-dim)"
        };
    }

    private (int Long, int Short) GetPowerLevel(string ticker)
    {
        var recent = ticks.Where(t => t.Ticker == ticker).TakeLast(50).ToList();
        if (!recent.Any()) return (50, 50);

        int up = recent.Count(t => t.Type == TickType.Up);
        int down = recent.Count(t => t.Type == TickType.Down);
        
        if (up == 0 && down == 0) return (50, 50);
        
        int total = up + down;
        int longPct = (int)Math.Round((double)up / total * 100);
        return (longPct, 100 - longPct);
    }

    private string GetSparklinePoints(string ticker)
    {
        var recent = ticks.Where(t => t.Ticker == ticker).TakeLast(30).ToList();
        if (recent.Count < 2) return "0,20 100,20";

        decimal min = recent.Min(t => t.Price);
        decimal max = recent.Max(t => t.Price);
        decimal range = max - min;
        if (range == 0) range = 1;

        var points = new List<string>();
        for (int i = 0; i < recent.Count; i++)
        {
            double x = (double)i / (recent.Count - 1) * 100;
            // Y is inverted in SVG (0 is top)
            double y = 40 - (double)((recent[i].Price - min) / range * 30 + 5);
            points.Add($"{x:F1},{y:F1}");
        }
        return string.Join(" ", points);
    }

    public void Dispose()
    {
        _subscription?.Dispose();
    }
}
